# ── jb-whisper environment variables ───────────────────────────────────────

# Shared secret sent in the X-Service-Key header by every client.
# Generate a strong random string: openssl rand -hex 32
SERVICE_KEY=change-me-random-string

# Port the server listens on inside the container.
PORT=8001

# How many /translate jobs run in parallel.
# Each job uses ~4-8 GB RAM while Whisper is active.
# Keep at 1-2 on a server with 16 GB RAM.
MAX_CONCURRENT_JOBS=2
