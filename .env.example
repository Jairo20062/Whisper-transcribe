# ── jb-whisper environment variables ───────────────────────────────────────

# Shared secret sent in the X-Service-Key header (HTTP) or ?key= param (WebSocket).
# Generate a strong random string: openssl rand -hex 32
SERVICE_KEY=change-me-random-string

# Port the server listens on inside the container.
PORT=8001

# How many /translate jobs run in parallel.
# Each job uses ~4-8 GB RAM while Whisper is active.
# Keep at 1-2 on a server with 16 GB RAM.
MAX_CONCURRENT_JOBS=2

# Hugging Face access token — required for speaker diarization.
# Without this, /ws/transcribe still works but all speakers are labelled "Spreker 1".
# Get a token at https://huggingface.co/settings/tokens
# Accept the model licence at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
